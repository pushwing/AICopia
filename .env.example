#--------------------------------------------------------------------
# AICopia 환경 설정 (.env) — 로컬 개발용
# 이 파일을 .env로 복사한 뒤 값을 실제 환경에 맞게 채우세요.
# .env는 절대 커밋하지 마세요 (.gitignore 처리됨).
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE (default 그룹)
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = ci4-shop
database.default.username =
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# DATABASE (tests 그룹 — 로컬 테스트용, default와 같은 MySQL DB 권장)
# CLAUDE.md 규칙: MySQL 필수, DBPrefix 비움
#--------------------------------------------------------------------
database.tests.hostname = localhost
database.tests.database = aicopia_test
database.tests.username = root
database.tests.password =
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
# 생성: php spark key:generate --show
#--------------------------------------------------------------------
encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4

#--------------------------------------------------------------------
# AI 프로바이더 (groq | claude | openrouter)
#--------------------------------------------------------------------
AI_PROVIDER = groq
GROQ_API_KEY =
ANTHROPIC_API_KEY =
OPENROUTER_API_KEY =
OPENROUTER_MODEL =

#--------------------------------------------------------------------
# 이메일 / SMTP
#--------------------------------------------------------------------
EMAIL_FROM_ADDRESS =
EMAIL_SMTP_HOST =
EMAIL_SMTP_USER =
EMAIL_SMTP_PASS =
EMAIL_SMTP_PORT = 587
EMAIL_SMTP_CRYPTO = tls

#--------------------------------------------------------------------
# 에디터
#--------------------------------------------------------------------
editor.tinymce_api_key =

#--------------------------------------------------------------------
# PG 결제 키 (사용하는 PG만 채우세요)
#--------------------------------------------------------------------
TOSS_CLIENT_KEY =
TOSS_SECRET_KEY =
INICIS_MERCHANT_ID =
INICIS_SIGN_KEY =
NICEPAY_CLIENT_ID =
NICEPAY_SECRET_KEY =
KAKAOPAY_CID =
KAKAOPAY_SECRET_KEY =
NAVERPAY_CLIENT_ID =
NAVERPAY_CLIENT_SECRET =
NAVERPAY_CHAIN_ID =
PAYCO_SELLER_KEY =
PAYCO_SECRET_KEY =

#--------------------------------------------------------------------
# 소셜 로그인 (OAuth) — 사용하는 provider만 채우세요
#--------------------------------------------------------------------
oauth.naver.client_id =
oauth.naver.client_secret =
oauth.kakao.client_id =
oauth.kakao.client_secret =
oauth.google.client_id =
oauth.google.client_secret =
